<article class="profile-card <%= currentPage %>" data-userid="<%= profile.id %>">
	<img class="profile-image" src="<%= profile.image %>" alt="profile picture">
	<img class="corner-logo" src="fadefinder-inline.png" alt="fadefinder logo">

	<h1 class="profile-name">
		<%= profile.name %>
	</h1>
	<div class="profile-stats">

		<p>
			📏 <%= profile.height.ft %>'<%= profile.height.in %>" ⚖️ <%= profile.weight %> lbs
		</p>
		<p>
			🪪 <%= getAgeFromDate(profile.birthday) %> years old
		</p>
	</div>

</article>